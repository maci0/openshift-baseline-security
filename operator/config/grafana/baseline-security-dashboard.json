{
  "title": "Baseline Security - Compliance",
  "uid": "baseline-security-compliance",
  "schemaVersion": 39,
  "editable": true,
  "tags": ["compliance", "baseline-security"],
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Compliance score",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "unit": "none" }
      },
      "targets": [
        {
          "expr": "max(baseline_security_compliance_score >= 0)",
          "legendFormat": "score",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Checks by status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "sum by (status) (max by (profile, status) (baseline_security_checks))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Failing checks by profile",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "max by (profile) (baseline_security_checks{status=\"fail\"})",
          "legendFormat": "{{profile}}",
          "refId": "A"
        }
      ]
    }
  ]
}
