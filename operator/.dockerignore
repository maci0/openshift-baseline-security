bin/
*.log

# Shared by operator/Dockerfile, bundle.Dockerfile, and catalog.Dockerfile.
# Do not exclude bundle/ or catalog/: those contexts need them (COPY fails
# otherwise). Operator image only COPYs api/cmd/internal so extra context is fine.
test/
hack/
config/
**/*_test.go
internal/controller/testdata/
Makefile
.golangci.yml
.dockerignore
*.md
# Keep secrets and VCS metadata out of the image build context.
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*kubeconfig*
id_rsa*
id_ed25519*
.git
.gitignore
# Local IDE / Python bytecode must not enter the context.
.vscode/
.idea/
**/__pycache__/
*.py[cod]
