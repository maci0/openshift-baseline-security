{
  "name": "baseline-security-console-plugin",
  "version": "0.4.0",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && NODE_ENV=production SOURCE_DATE_EPOCH=${SOURCE_DATE_EPOCH:-0} yarn ts-node node_modules/.bin/webpack",
    "build-dev": "yarn clean && yarn ts-node node_modules/.bin/webpack",
    "start": "yarn ts-node node_modules/.bin/webpack serve",
    "ts-node": "ts-node -O '{\"module\":\"commonjs\"}'",
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test-e2e": "playwright test -c e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk": "4.22.0",
    "@openshift-console/dynamic-plugin-sdk-webpack": "4.22.0",
    "@patternfly/react-charts": "~8.4.1",
    "@patternfly/react-core": "^6.4.3",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-table": "^6.4.3",
    "@playwright/test": "^1.61.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^9.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "i18next": "~25.6.2",
    "jest": "^30.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "~16.5.8",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "victory": "^37.3.6",
    "webpack": "^5.107.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.4"
  },
  "consolePlugin": {
    "name": "baseline-security-console-plugin",
    "version": "0.4.0",
    "displayName": "Baseline Security",
    "description": "Cluster compliance baseline dashboard driven by the Compliance Operator.",
    "exposedModules": {
      "CompliancePage": "./components/CompliancePage",
      "ClusterScoreItem": "./components/ClusterScoreItem"
    },
    "dependencies": {
      "@console/pluginAPI": ">=4.22.0-0"
    }
  },
  "resolutions": {
    "glob": "^13.0.6",
    "test-exclude": "^8.0.0",
    "uuid": "^11.1.1"
  },
  "packageManager": "yarn@4.14.1"
}
