# Copy to .env and fill in values for live-console Playwright e2e.
# Never commit .env (gitignored). `yarn test-e2e` loads only these keys from
# .env (CONSOLE_URL, KUBEADMIN_*, SCREENSHOT_DIR). Non-empty process env still
# wins, so CI can inject secrets without a file; empty/whitespace process env
# does not block .env. Optional `export KEY=value` is accepted.
# Manual alternative: set -a && . ./.env && set +a && yarn test-e2e
#
# Required:
# CONSOLE_URL: absolute http(s) URL only (no user:pass@host; use KUBEADMIN_*).
CONSOLE_URL=https://console-openshift-console.apps.example.com
KUBEADMIN_PASSWORD=

# Optional:
# KUBEADMIN_USER=kubeadmin
# SCREENSHOT_DIR=../docs/screenshots
# (blank SCREENSHOT_DIR uses docs/screenshots; do not set empty to mean cwd)
