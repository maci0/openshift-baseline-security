# Copy to .env and fill in values for live-console Playwright e2e.
# Never commit .env (gitignored). Source before running:
#   set -a && . ./.env && set +a && yarn test-e2e
#
# Required:
CONSOLE_URL=https://console-openshift-console.apps.example.com
KUBEADMIN_PASSWORD=

# Optional:
# KUBEADMIN_USER=kubeadmin
# SCREENSHOT_DIR=../docs/screenshots
